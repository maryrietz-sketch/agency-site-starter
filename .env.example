# Copy this file to .env for local development. Do not commit real secrets.

# Public Sanity read settings used by the Astro web app.
PUBLIC_SANITY_PROJECT_ID=yourprojectid
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-01-01
PUBLIC_SANITY_USE_CDN=true

# Public site URL used for canonical URLs and schema.
PUBLIC_SITE_URL=https://example.com

# Optional public analytics IDs. Leave blank until approved by the client.
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_PLAUSIBLE_DOMAIN=

# Optional public integration links. These should point to approved third-party providers.
PUBLIC_DEFAULT_BOOKING_URL=
PUBLIC_DEFAULT_ORDER_URL=
PUBLIC_DEFAULT_ECOMMERCE_URL=
PUBLIC_DEFAULT_GIVING_URL=
PUBLIC_DEFAULT_LIVESTREAM_URL=
PUBLIC_DEFAULT_CHURCH_APP_URL=
PUBLIC_DEFAULT_EVENTS_URL=
PUBLIC_DEFAULT_SERMONS_URL=

# Optional form provider endpoint. Do not put private API keys in public variables.
PUBLIC_CONTACT_FORM_ENDPOINT=

# Sanity Studio settings. No write token is required for the static web build.
SANITY_STUDIO_PROJECT_ID=yourprojectid
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2025-01-01
SANITY_STUDIO_PROJECT_TITLE=Agency Starter Studio
