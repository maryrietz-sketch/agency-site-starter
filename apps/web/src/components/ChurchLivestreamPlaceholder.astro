---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Livestream integration placeholder', url = '#', notes = 'Use YouTube, Vimeo, Facebook Live, Church Online Platform, Resi, BoxCast, or the church’s existing livestream host.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
