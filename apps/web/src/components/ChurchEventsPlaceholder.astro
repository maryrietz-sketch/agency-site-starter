---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Events integration placeholder', url = '#', notes = 'Use Planning Center Registrations, Church Center, Google Calendar, Eventbrite, or the client’s existing event system.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
