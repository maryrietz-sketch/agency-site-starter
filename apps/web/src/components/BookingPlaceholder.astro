---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Booking integration placeholder', url = '#', notes = 'Use Calendly, Square Appointments, Acuity, Jane, Boulevard, or another approved booking platform.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
