---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Sermons/media integration placeholder', url = '#', notes = 'Use YouTube, Vimeo, Spotify, Apple Podcasts, Subsplash, or the church’s existing sermon/media platform.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
