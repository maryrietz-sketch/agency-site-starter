---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Ordering integration placeholder', url = '#', notes = 'Use Square, Toast, Shopify, Clover, DoorDash Storefront, or another approved ordering provider as the source of truth.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
