---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Church app integration placeholder', url = '#', notes = 'Link to Church Center, Subsplash, MinistryOne, or the church’s existing app source.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
