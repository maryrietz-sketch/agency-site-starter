---
const endpoint = import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT || '';
---
<form class="contact-form" method="post" action={endpoint || '#'} aria-label="Contact form placeholder">
  <p class="notice">Placeholder only. Connect an approved form provider such as Resend, Basin, Formspree, or the client’s CRM before production.</p>
  <label>Name <input name="name" autocomplete="name" required /></label>
  <label>Email <input type="email" name="email" autocomplete="email" required /></label>
  <label>Message <textarea name="message" rows="5" required></textarea></label>
  <button type="submit" disabled={!endpoint}>Send message</button>
</form>
