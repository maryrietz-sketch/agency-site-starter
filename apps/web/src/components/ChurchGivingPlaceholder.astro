---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'Giving integration placeholder', url = '#', notes = 'Use Planning Center Giving, Church Center, Pushpay, Tithely, Subsplash, MinistryPlatform, or the church’s approved giving provider.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
