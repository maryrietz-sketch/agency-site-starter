---
interface Props {
  label?: string;
  url?: string;
  notes?: string;
}
const { label = 'E-commerce integration placeholder', url = '#', notes = 'Use Shopify, Square, WooCommerce, or another proven platform for checkout, taxes, inventory, shipping, refunds, and customer accounts.' } = Astro.props;
---
<section class="integration-card" aria-label={label}>
  <h2>{label}</h2>
  <p>{notes}</p>
  <a class="button" href={url} aria-disabled={url === '#'}>Add approved integration link</a>
</section>
